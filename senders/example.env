# Copy this file to senders/<yourname>.env and fill it in.
# Real sender files are gitignored; only this example is committed.

# Used in the From: header of every email you send.
SENDER_NAME=Ada Lovelace
SENDER_EMAIL=ada@example.com

# SMTP = outgoing mail. Common providers:
#   Gmail:    smtp.gmail.com          port 587   (create an App Password: https://myaccount.google.com/apppasswords)
#   Outlook:  smtp-mail.outlook.com   port 587
#   Yahoo:    smtp.mail.yahoo.com     port 587   (App Password required)
#   University/work: ask IT or search "<university> smtp settings"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ada@example.com
SMTP_PASSWORD=your-app-password-here

# IMAP = incoming mail, used ONLY to copy sent emails into your Sent folder so
# they show up in your mail client. Optional: leave IMAP_HOST empty to skip.
#   Gmail: imap.gmail.com   Outlook: outlook.office365.com
IMAP_HOST=
IMAP_PORT=993
# IMAP_USER / IMAP_PASSWORD default to the SMTP values if not set.

# Pause between emails in batch sends (milliseconds). Be gentle with your provider.
EMAIL_DELAY_MS=10000
