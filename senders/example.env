# Copy this file to senders/<yourname>.env and fill it in.
# Real sender files are gitignored; only this example is committed.

# Used in the From: header of every email you send.
SENDER_NAME=Ada Lovelace
SENDER_EMAIL=ada@example.com

# SMTP = outgoing mail.
# Tested so far: university mailboxes only (TUM via LRZ). For yours, search
# "<your university> smtp settings" or ask IT for host + port.
# Gmail / Outlook / Yahoo: untested, future work (see senders/README.md).
#
# TUM / LRZ note: log in with your LRZ Kennung (e.g. "ab12cde"), NOT your
# @tum.de email address. Settings: SMTP_HOST=postout.lrz.de, SMTP_PORT=587,
# SMTP_SECURE=false, SMTP_USER=<your LRZ Kennung>.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ada@example.com
SMTP_PASSWORD=your-app-password-here

# IMAP = incoming mail, used ONLY to copy sent emails into your Sent folder so
# they show up in your mail client. Optional: leave IMAP_HOST empty to skip.
# IMAP_USER / IMAP_PASSWORD default to the SMTP values if not set, so with a
# matching login you only need IMAP_HOST.
#
# TUM / LRZ note: IMAP_HOST=xmail.mwn.de, IMAP_PORT=993, and authenticate with
# the same LRZ Kennung + password as SMTP (NOT the @tum.de email). xmail.mwn.de
# is TUM's Exchange server and copies sent mail over IMAP fine; if you get
# AUTHENTICATIONFAILED here, the cause is almost always the email address being
# used as the username instead of the Kennung, not an Exchange limitation.
IMAP_HOST=
IMAP_PORT=993

# Pause between emails in batch sends (milliseconds). Be gentle with your provider.
EMAIL_DELAY_MS=10000
